VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel : bouton « Parcourir la démo » sur /login (même email/mot de passe qu’un compte Auth réel + seed)
# Les valeurs VITE_ sont incluses dans le JS public — réservez un compte / projet Supabase dédiés.
# Mot de passe : doit respecter la politique Supabase Auth (souvent ≥ 6 caractères) pour que la connexion réussisse.
# VITE_DEMO_LOGIN_EMAIL=demo@votredomaine.test
# VITE_DEMO_LOGIN_PASSWORD=

# Scripts seed (pnpm seed:clear, pnpm seed:bulk) — jamais dans le navigateur
SUPABASE_SERVICE_ROLE_KEY=

# Optionnel : email cible pour pnpm seed:bulk (sinon 1er argument CLI ou défaut script)
# SEED_DEMO_EMAIL=
